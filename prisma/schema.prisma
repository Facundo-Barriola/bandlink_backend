  bands          bands     @relation(fields: [band_id], references: [band_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_band_members_band_id")
  users          users     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_band_members_user_id")

  @@unique([band_id, user_id], map: "uq_band_members_band_id_user_id")
  @@index([band_id], map: "ix_band_members_band_id")
