/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model band_members {
  band_member_id String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  band_id        String    @unique(map: "uq_band_members_one_owner", where: raw("((role = 'owner'::text) AND (left_at IS NULL))")) @db.Uuid
