  @@index([room_id, starts_at], map: "ix_bookings_room_id_starts_at")
  @@index([room_id, starts_at, ends_at], map: "ix_bookings_room_time")
  @@index([status], map: "ix_bookings_status")
  @@index([user_id, starts_at], map: "ix_bookings_user_id_starts_at")
