generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["auth", "bands", "bookings", "chat", "events", "geo", "media", "music", "notifications", "payments", "prisma", "public", "reviews", "social", "studios"]
}

model email_verification_tokens {
  token_id    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String    @db.Uuid
  token_hash  String    @unique(map: "uq_email_verification_token_hash")
  expires_at  DateTime  @db.Timestamptz(6)
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  consumed_at DateTime? @db.Timestamptz(6)
  ip          String?   @db.Inet
  user_agent  String?
  users       users     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([consumed_at], map: "ix_email_verif_tokens_consumed")
  @@index([expires_at], map: "ix_email_verif_tokens_expires")
  @@index([user_id], map: "ix_email_verif_tokens_user_id")
  @@schema("auth")
}

model oauth_accounts {
  oauth_account_id String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String    @db.Uuid
  provider         String
  provider_user_id String    @db.Uuid
  access_token     String?
  refresh_token    String?
  token_expires_at DateTime? @db.Timestamptz(6)
  scopes           String?
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  updated_at       DateTime? @default(now()) @db.Timestamptz(6)
  users            users     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_oauth_accounts_user_id")

  @@unique([user_id, provider])
  @@unique([provider, provider_user_id], map: "uq_oauth_accounts_provider_provider_user_id")
  @@unique([user_id, provider], map: "uq_oauth_accounts_user_id_provider")
  @@index([user_id], map: "ix_oauth_accounts_user_id")
  @@schema("auth")
}

model password_reset_tokens {
  token_id    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id     String    @db.Uuid
  token_hash  String    @unique(map: "uq_password_reset_token_hash")
  expires_at  DateTime  @db.Timestamptz(6)
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  consumed_at DateTime? @db.Timestamptz(6)
  ip          String?   @db.Inet
  user_agent  String?
  users       users     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([consumed_at], map: "ix_pwreset_tokens_consumed")
  @@index([expires_at], map: "ix_pwreset_tokens_expires")
  @@index([user_id], map: "ix_pwreset_tokens_user_id")
  @@schema("auth")
}

model sessions {
  session_id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id            String    @db.Uuid
  refresh_token_hash String?   @unique(map: "uq_sessions_refresh_token_hash")
  user_agent         String?
  ip                 String?   @db.Inet
  expires_at         DateTime? @db.Timestamptz(6)
  created_at         DateTime  @default(now()) @db.Timestamptz(6)
  revoked_at         DateTime? @db.Timestamptz(6)
  users              users     @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_sessions_user_id")

  @@index([expires_at], map: "ix_sessions_expires_at")
  @@index([user_id], map: "ix_sessions_user_id")
  @@schema("auth")
}

model user_roles {
  user_role_id String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String   @db.Uuid
  role         String?
  created_at   DateTime @default(now()) @db.Timestamptz(6)
  users        users    @relation(fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_roles_user_id")

  @@unique([user_id, role], map: "uq_user_roles_user_id_role")
  @@unique([user_id, role])
  @@index([role], map: "ix_user_roles_role")
  @@index([user_id], map: "ix_user_roles_user_id")
  @@schema("auth")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model users {
  user_id                                             String                      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                                               String                      @unique(map: "uq_users_email") @db.Citext
  username                                            String                      @unique(map: "uq_users_username") @db.Citext
  password_hash                                       String
  display_name                                        String?
  bio                                                 String?
  phone                                               String?
  birthdate                                           DateTime?                   @db.Date
  place_id                                            String?                     @db.Uuid
  profile_visibility                                  String?
  is_active                                           Boolean?                    @default(true)
  email_verified                                      Boolean                     @default(false)
  created_at                                          DateTime                    @default(now()) @db.Timestamptz(6)
  updated_at                                          DateTime?                   @default(now()) @db.Timestamptz(6)
  email_verification_tokens                           email_verification_tokens[]
  oauth_accounts                                      oauth_accounts[]
  password_reset_tokens                               password_reset_tokens[]
  sessions                                            sessions[]
  user_roles                                          user_roles[]
  places                                              places?                     @relation(fields: [place_id], references: [place_id], onUpdate: NoAction, map: "fk_users_place_id")
  band_invite_band_invite_from_user_idTousers         band_invite[]               @relation("band_invite_from_user_idTousers")
  band_invite_band_invite_to_user_idTousers           band_invite[]               @relation("band_invite_to_user_idTousers")
  band_members                                        band_members[]
  bands                                               bands[]
  opening_applications                                opening_applications[]
  booking_status_history                              booking_status_history[]
  bookings                                            bookings[]
  conversation_members                                conversation_members[]
  message_reads                                       message_reads[]
  messages                                            messages[]
  event_attendees                                     event_attendees[]
  event_invites_event_invites_from_user_idTousers     event_invites[]             @relation("event_invites_from_user_idTousers")
  event_invites_event_invites_to_user_idTousers       event_invites[]             @relation("event_invites_to_user_idTousers")
  events                                              events[]
  user_media                                          user_media[]
  musician_genre                                      musician_genre[]
  musician_instrument                                 musician_instrument[]
  musician_profile                                    musician_profile?
  email_outbox                                        email_outbox[]
  notifications                                       notifications[]
  push_subscriptions                                  push_subscriptions[]
  reports_reports_reporter_user_idTousers             reports[]                   @relation("reports_reporter_user_idTousers")
  reports_reports_resolved_byTousers                  reports[]                   @relation("reports_resolved_byTousers")
  studio_reviews                                      studio_reviews[]
  user_reviews_user_reviews_user_reviewed_idTousers   user_reviews[]              @relation("user_reviews_user_reviewed_idTousers")
  user_reviews_user_reviews_user_reviewer_idTousers   user_reviews[]              @relation("user_reviews_user_reviewer_idTousers")
  blocks_blocks_blocked_user_idTousers                blocks[]                    @relation("blocks_blocked_user_idTousers")
  blocks_blocks_blocker_user_idTousers                blocks[]                    @relation("blocks_blocker_user_idTousers")
  follows                                             follows[]
  friend_requests_friend_requests_from_user_idTousers friend_requests[]           @relation("friend_requests_from_user_idTousers")
  friend_requests_friend_requests_to_user_idTousers   friend_requests[]           @relation("friend_requests_to_user_idTousers")
  friendships_friendships_user_id1Tousers             friendships[]               @relation("friendships_user_id1Tousers")
  friendships_friendships_user_id2Tousers             friendships[]               @relation("friendships_user_id2Tousers")
  room_blocks                                         room_blocks[]
  studios                                             studios[]

  @@index([place_id], map: "ix_users_place_id")
  @@schema("auth")
}

model band_genres {
  band_genre_id String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
