  genres        genres   @relation(fields: [genre_id], references: [genre_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_band_genres_genre_id")

  @@unique([band_id, genre_id], map: "uq_band_genres_band_id_genre_id")
  @@schema("bands")
}

