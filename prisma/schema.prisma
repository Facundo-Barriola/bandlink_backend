  phone           String?
  is_active       Boolean?          @default(true)
  created_at      DateTime          @default(now()) @db.Timestamptz(6)
  studio_reviews  studio_reviews[]
  rehearsal_rooms rehearsal_rooms[]
  users           users             @relation(fields: [owner_user_id], references: [user_id], onUpdate: NoAction, map: "fk_studios_owner_user_id")
  places          places?           @relation(fields: [place_id], references: [place_id], onUpdate: NoAction, map: "fk_studios_place_id")

  @@index([owner_user_id], map: "ix_studios_owner_user_id")
  @@index([place_id], map: "ix_studios_place_id")
  @@schema("studios")
}
